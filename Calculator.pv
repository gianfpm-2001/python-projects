# Simple Calculator

def add(a, b):
    return a + b

def subtract(a, b):
    return a - b

def multiply(a, b):
    return a * b

def divide(a, b):
    if b == 0:
        return "Error: Cannot divide by zero"
    return a / b

print("Simple Calculator")
print("16 + 4 =", add(16, 4))
print("20 - 5 =", subtract(20, 5))
print("6 x 7 =", multiply(6, 7))
print("100 / 4 =", divide(100, 4))
